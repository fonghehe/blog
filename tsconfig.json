{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["docs/**/*.ts", "docs/**/*.vue", "docs/.vitepress/**/*.ts"],
  "exclude": [
    "node_modules",
    "docs/.vitepress/dist",
    "docs/.vitepress/dist-*",
    "docs/.vitepress/cache"
  ]
}
